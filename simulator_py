# CONSTRUCTION DU PAYLOAD
# ─────────────────────────────────────────────────────────────────────────────

def build_http_payload(index: int, trigger: str = "index_change") -> dict:
    """Construit un payload HTTP identique à celui du watcher Mac."""
    eff = EFFECTS[index]
    return {
        "source":             "windows_simulator",
        "template_id":        f"lumabooth_index_{index}",
        "selected_index":     index,
        "action_index":       index,
        "label":              eff["label"],
        "color_hex":          eff["color_hex"],
        "r":                  eff["r"],
        "g":                  eff["g"],
        "b":                  eff["b"],
        "brightness":         BRIGHTNESS_DEFAULT,
        "transition_ms":      TRANSITION_MS,
        "trigger":            trigger,
        "session_generation": SESSION_GENERATION,
        "action_key":         _next_action_key(trigger, index),
        "timestamp":          datetime.datetime.now().isoformat(),
    }

def build_serial_payload(index: int, trigger: str = "index_change") -> dict:
    """Payload USB = payload HTTP + champ cmd."""
    p = build_http_payload(index, trigger)
    p["cmd"] = "set-color"
    return p

# ─────────────────────────────────────────────────────────────────────────────
# TRANSPORT HTTP
# ─────────────────────────────────────────────────────────────────────────────

def http_get(path: str) -> tuple:
    """GET ESP32_URL/path. Retourne (ok, data_or_msg)."""
    if not _HTTP_OK:
        return (False, "requests non installé")
    url = ESP32_URL.rstrip("/") + path
    try:
        r = _requests.get(url, timeout=HTTP_TIMEOUT)
        data = r.json() if r.headers.get("Content-Type","").startswith("application/json") else r.text
        return (r.status_code == 200, data)
    except _requests.exceptions.ConnectionError:
        return (False, f"Connexion refusée — ESP32 injoignable ({url})")
    except _requests.exceptions.Timeout:
        return (False, f"Timeout ({HTTP_TIMEOUT}s)")
    except Exception as e:
        return (False, str(e))

def http_post(path: str, payload: dict) -> tuple:
    """POST JSON vers ESP32_URL/path. Retourne (ok, data_or_msg)."""
    if not _HTTP_OK:
        return (False, "requests non installé")
    url = ESP32_URL.rstrip("/") + path
    try:
        r = _requests.post(url, json=payload, timeout=HTTP_TIMEOUT)
        data = r.json() if r.headers.get("Content-Type","").startswith("application/json") else r.text
        return (r.status_code in (200, 201), data)
    except _requests.exceptions.ConnectionError:
        return (False, f"Connexion refusée — ESP32 injoignable ({url})")
    except _requests.exceptions.Timeout:
        return (False, f"Timeout ({HTTP_TIMEOUT}s)")
    except Exception as e:
        return (False, str(e))

def print_http_result(ok: bool, data) -> None:
    if ok:
        log.info(f"HTTP OK → {data}")
    else:
        log.error(f"HTTP ERREUR → {data}")

# ─────────────────────────────────────────────────────────────────────────────
# TRANSPORT USB SERIAL
# ─────────────────────────────────────────────────────────────────────────────

def list_serial_ports() -> list:
    """Liste les ports COM disponibles sur Windows."""
    if not _SERIAL_OK:
        return []
    return [p.device for p in _list_ports.comports()]

def serial_connect(port: str = None) -> bool:
    """Ouvre la connexion série persistante. Retourne True si OK."""
    global _serial_conn
    target = port or SERIAL_PORT
    if not _SERIAL_OK:
        log.error("pyserial non installé")
        return False
    try:
        if _serial_conn and _serial_conn.is_open:
            _serial_conn.close()
        conn = _serial.Serial()
        conn.port     = target
        conn.baudrate = SERIAL_BAUD
        conn.timeout  = 2
        # Désactiver DTR/RTS pour éviter reset ESP32 à l'ouverture
        conn.dtr = False
        conn.rts = False
        conn.open()
        conn.dtr = False
        conn.rts = False
        time.sleep(0.1)
        conn.reset_input_buffer()
        _serial_conn = conn
        log.info(f"Port {target} ouvert à {SERIAL_BAUD} bauds")
        return True
    except _serial.SerialException as e:
        log.error(f"Impossible d'ouvrir {target}: {e}")
        return False
    except Exception as e:
        log.error(f"Erreur ouverture série: {e}")
        return False

def serial_send_cmd(cmd_dict: dict) -> tuple:
    """
    Envoie une commande JSON sur le port série.
    Retourne (ok, message).
    """
    global _serial_conn
    if not _SERIAL_OK:
        return (False, "pyserial non installé")
    if _serial_conn is None or not _serial_conn.is_open:
        log.warning("Port série non ouvert — tentative de connexion...")
        if not serial_connect():
            return (False, "Port série inaccessible")

    line = json.dumps(cmd_dict, separators=(",", ":")) + "\n"
    try:
        _serial_conn.reset_input_buffer()
        _serial_conn.write(line.encode("utf-8"))
        _serial_conn.flush()
    except Exception as e:
        _serial_conn = None
        return (False, f"Erreur écriture: {e}")

    # Lire la réponse — ignorer les lignes de log [WIFI], [LED], etc.
    deadline = time.time() + 3.0
    while time.time() < deadline:
        try:
            raw = _serial_conn.readline()
        except Exception as e:
            return (False, f"Erreur lecture: {e}")
        if not raw:
            continue
        text = raw.decode("utf-8", errors="replace").strip()
        if not text or text.startswith("["):
            continue   # ligne de log ESP32, ignorer
        try:
            data = json.loads(text)
            if "success" in data:
                return (data["success"], data)
        except json.JSONDecodeError:
            continue

    return (False, "Pas de réponse JSON (timeout)")

def print_serial_result(ok: bool, data) -> None:
    if ok:
        log.info(f"USB OK → {data}")
    else:
        log.error(f"USB ERREUR → {data}")

