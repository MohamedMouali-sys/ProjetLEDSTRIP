            port_input = input(f"Port à utiliser [{suggestion}] : ").strip()
            SERIAL_PORT = port_input or suggestion
            serial_connect(SERIAL_PORT)

        elif choice == "10":
            action_effect_usb(0)

        elif choice == "11":
            action_effect_usb(1)

        elif choice == "12":
