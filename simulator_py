    print(f"\n[USB] Effect {index+1} — {eff['label']} {eff['color_hex']}")
    payload = build_serial_payload(index, trigger)
    ok, data = serial_send_cmd(payload)
    print_serial_result(ok, data)

def action_off_usb():
    print("\n[USB] cmd: off")
    ok, data = serial_send_cmd({"cmd": "off"})
    print_serial_result(ok, data)

def action_status_usb():
    print("\n[USB] cmd: status")
    ok, data = serial_send_cmd({"cmd": "status"})
    print_serial_result(ok, data)

