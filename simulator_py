def show_menu():
    port_status = (_serial_conn.port if _serial_conn and _serial_conn.is_open
                   else SERIAL_PORT + " (non connecté)")
    api_display = API_URL[:45] + "…" if len(API_URL) > 47 else API_URL
    print(MENU.format(
        esp32_url=ESP32_URL,
        port=port_status,
        api_url=api_display,
    ))

