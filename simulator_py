            action_off_usb()

        elif choice == "15":
            action_status_usb()

        elif choice == "16":
            run_scenario_http()

        elif choice == "17":
            run_scenario_usb()

        elif choice == "18":
            new_url = input(f"Nouvelle IP/URL ESP32 [{ESP32_URL}] : ").strip()
            if new_url:
                ESP32_URL = new_url.rstrip("/")
                log.info(f"ESP32 URL changée : {ESP32_URL}")

        elif choice == "19":
            action_config_api_http()

        elif choice == "20":
            action_config_api_usb()

        elif choice == "21":
            action_set_mode_http("local_push")

        elif choice == "22":
            action_set_mode_http("api_pull")

        elif choice == "23":
            action_set_mode_http("dual")

        elif choice == "24":
            action_set_mode_usb("local_push")

        elif choice == "25":
            action_set_mode_usb("api_pull")

        elif choice == "26":
            action_set_mode_usb("dual")

        elif choice == "27":
