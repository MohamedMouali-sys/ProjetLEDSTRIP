def _build_config_payload(mode: str) -> dict:
    """Construit le payload /config avec les paramètres API actuels."""
    return {
        "mode":                           mode,
        "api_url":                        API_URL,
        "api_interval_ms":                API_INTERVAL_MS,
        "direct_priority_ms":             DIRECT_PRIORITY_MS,
        "usb_priority_ms":                USB_PRIORITY_MS,
        "allow_http_during_usb_priority": ALLOW_HTTP_DURING_USB_PRIORITY,
    }

def action_config_api_http(mode: str = "dual"):
    """19 — Configure l'API distante sur l'ESP32 via HTTP POST /config."""
    payload = _build_config_payload(mode)
    print(f"\n[HTTP] POST /config — mode={mode} api_url={API_URL}")
    ok, data = http_post("/config", payload)
    print_http_result(ok, data)

def action_config_api_usb(mode: str = "dual"):
    """20 — Configure l'API distante sur l'ESP32 via USB cmd:config."""
    payload = _build_config_payload(mode)
    payload["cmd"] = "config"
    print(f"\n[USB] cmd:config — mode={mode} api_url={API_URL}")
    ok, data = serial_send_cmd(payload)
    print_serial_result(ok, data)

def action_set_mode_http(mode: str):
    """Envoie le mode choisi + URL API actuelle via HTTP."""
    payload = _build_config_payload(mode)
    print(f"\n[HTTP] POST /config — mode={mode}")
    ok, data = http_post("/config", payload)
    print_http_result(ok, data)

def action_set_mode_usb(mode: str):
    """Envoie le mode choisi + URL API actuelle via USB."""
    payload = _build_config_payload(mode)
    payload["cmd"] = "config"
    print(f"\n[USB] cmd:config — mode={mode}")
    ok, data = serial_send_cmd(payload)
    print_serial_result(ok, data)

def action_show_esp32_status():
    """28 — GET /status et affiche les champs essentiels."""
    print("\n[HTTP] GET /status")
    ok, data = http_get("/status")
    if not ok:
        print_http_result(ok, data)
        return
    fields = [
        "mode", "api_url", "api_interval_ms", "direct_priority_ms",
        "usb_priority_ms", "last_source", "wifi_connected",
        "usb_priority_active", "local_priority_active",
        "last_r", "last_g", "last_b", "last_brightness",
        "last_template_id", "uptime_ms",
    ]
    print()
    print("  ┌─ Configuration ESP32 ─────────────────────────────")
    if isinstance(data, dict):
        for f in fields:
            if f in data:
                print(f"  │  {f:<34} = {data[f]}")
    else:
        print(f"  │  {data}")
    print("  └───────────────────────────────────────────────────")

