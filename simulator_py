def run_scenario_http():
    """
    Simule une session LumaBooth complète via HTTP :
      accueil Effect 1 → Effect 2 → Effect 4 → session photo → accueil → off
    """
    print("\n" + "═"*60)
    print("SCÉNARIO AUTOMATIQUE HTTP")
    print("═"*60)

    steps = [
        ("initial accueil",    0, "initial",      2),
        ("template change",    1, "index_change", 2),
        ("template change",    3, "index_change", 2),
        ("session photo",     -1, "in_session",   3),  # -1 = pas d'envoi
        ("reset accueil",      0, "reset_idle",   2),
        ("off",               -2, "off",          0),   # -2 = /off
    ]

    for label, idx, trigger, wait in steps:
        print(f"\n  ▶ {label}")
        if idx == -1:
            log.info(f"[SIM] {label} — aucune commande LED envoyée")
        elif idx == -2:
            action_off_http()
        else:
            action_effect_http(idx, trigger)
        if wait > 0:
            log.info(f"[SIM] Attente {wait}s...")
            time.sleep(wait)

    print("\n" + "═"*60)
    print("SCÉNARIO TERMINÉ")
    print("═"*60)

def run_scenario_usb():
    """
    Simule une session LumaBooth complète via USB Serial.
