/*
 * Applique et valide les champs de config communs à HTTP /config
 * et à la commande USB {"cmd":"config",...}.
 * Retourne une chaîne d'erreur ou "" si OK.
 */
String applyConfigFromDoc(JsonDocument& doc) {
  if (doc.containsKey("mode")) {
    ControlMode nm = parseMode(doc["mode"].as<String>());
    if ((int)nm == -1) return "invalid_mode";
    controlMode = nm;
  }
  if (doc.containsKey("api_url")) {
    apiUrl = doc["api_url"].as<String>();
    apiUrl.trim();
  }
  if (doc.containsKey("api_interval_ms")) {
    long v = doc["api_interval_ms"].as<long>();
    if (v < (long)API_INTERVAL_MIN_MS) return "invalid_api_interval_ms";
    apiIntervalMs = (unsigned long)v;
  }
  if (doc.containsKey("direct_priority_ms")) {
    long v = doc["direct_priority_ms"].as<long>();
    if (v < 0 || (unsigned long)v > PRIORITY_MAX_MS) return "invalid_direct_priority_ms";
    directPriorityMs = (unsigned long)v;
  }
  if (doc.containsKey("usb_priority_ms")) {
    long v = doc["usb_priority_ms"].as<long>();
    if (v < 0 || (unsigned long)v > PRIORITY_MAX_MS) return "invalid_usb_priority_ms";
    usbPriorityMs = (unsigned long)v;
  }
  if (doc.containsKey("allow_http_during_usb_priority")) {
    allowHttpDuringUsbPriority = doc["allow_http_during_usb_priority"].as<bool>();
  }
  return "";
}

