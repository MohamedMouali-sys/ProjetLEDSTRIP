// Délais de priorité
unsigned long directPriorityMs = 5000;   // HTTP local bloque l'API
unsigned long usbPriorityMs    = 5000;   // USB bloque HTTP + API
bool          allowHttpDuringUsbPriority = false;

// Timers des dernières commandes
unsigned long lastDirectCommandMs        = 0;  // dernière commande HTTP locale
unsigned long lastSerialCommandMs        = 0;  // dernière commande USB
unsigned long lastApiPollMs              = 0;
unsigned long lastWifiReconnectAttemptMs = 0;

// Dernier état LED
String   lastSource      = "none";
String   lastTemplateId  = "";
String   lastActionKey   = "";
uint8_t  lastR           = 0;
uint8_t  lastG           = 0;
uint8_t  lastB           = 0;
uint8_t  lastBrightness  = DEFAULT_BRIGHTNESS;
uint16_t lastTransitionMs = 500;

// Transition non bloquante
uint8_t       transR = 0, transG = 0, transB = 0;
uint8_t       targetR = 0, targetG = 0, targetB = 0;
uint8_t       targetBrightness = DEFAULT_BRIGHTNESS;
unsigned long transStart    = 0;
unsigned long transDuration = 0;
bool          inTransition  = false;
unsigned long lastLedFrameMs = 0;

// Buffer USB Serial
String serialBuffer = "";

// ═════════════════════════════════════════════════════════════════════════════
// HELPERS — PRIORITÉ
// ═════════════════════════════════════════════════════════════════════════════

bool isUsbPriorityActive() {
  return (lastSerialCommandMs > 0 &&
          (millis() - lastSerialCommandMs) < usbPriorityMs);
}

bool isLocalPriorityActive() {
  return (lastDirectCommandMs > 0 &&
          (millis() - lastDirectCommandMs) < directPriorityMs);
}

/*
 * canApplyHttpCommand — vrai si une commande HTTP locale peut être appliquée.
 * Bloqué si USB priority active ET allowHttpDuringUsbPriority == false.
 */
bool canApplyHttpCommand() {
  if (isUsbPriorityActive() && !allowHttpDuringUsbPriority) return false;
  return true;
}

/*
 * canApplyApiCommand — vrai si l'API peut écrire les LEDs.
 * Bloqué par USB priority ou HTTP local priority.
 */
bool canApplyApiCommand() {
  if (isUsbPriorityActive())    return false;
  if (isLocalPriorityActive())  return false;
  return true;
}

// ═════════════════════════════════════════════════════════════════════════════
// LED — APPLICATION ET TRANSITION
// ═════════════════════════════════════════════════════════════════════════════

void applyColor(uint8_t r, uint8_t g, uint8_t b,
                uint8_t brightness, uint16_t transitionMs) {
  lastR            = r;
  lastG            = g;
  lastB            = b;
  lastBrightness   = brightness;
  lastTransitionMs = transitionMs;

  if (transitionMs == 0) {
    inTransition = false;
    FastLED.setBrightness(brightness);
    fill_solid(leds, LED_COUNT, CRGB(r, g, b));
    FastLED.show();
    lastLedFrameMs = millis();
  } else {
    transR = leds[0].r;
    transG = leds[0].g;
    transB = leds[0].b;
    targetR          = r;
    targetG          = g;
    targetB          = b;
    targetBrightness = brightness;
    transStart       = millis();
    transDuration    = transitionMs;
    inTransition     = true;
  }
}

void updateTransition() {
  if (!inTransition) return;
  unsigned long now = millis();
  if (now - lastLedFrameMs < LED_FRAME_INTERVAL_MS) return;
  lastLedFrameMs = now;

  unsigned long elapsed = now - transStart;
  if (elapsed >= transDuration) {
    inTransition = false;
    FastLED.setBrightness(targetBrightness);
    fill_solid(leds, LED_COUNT, CRGB(targetR, targetG, targetB));
    FastLED.show();
    Serial.println("[LED] Transition complete.");
    return;
  }
  float t  = (float)elapsed / (float)transDuration;
  uint8_t r = (uint8_t)(transR + t * ((int)targetR - (int)transR));
  uint8_t g = (uint8_t)(transG + t * ((int)targetG - (int)transG));
  uint8_t b = (uint8_t)(transB + t * ((int)targetB - (int)transB));
  FastLED.setBrightness(targetBrightness);
  fill_solid(leds, LED_COUNT, CRGB(r, g, b));
  FastLED.show();
}

// ═════════════════════════════════════════════════════════════════════════════
// HELPER — APPLIQUER COULEUR DEPUIS JsonDocument
// ═════════════════════════════════════════════════════════════════════════════

/*
 * applyColorFromDoc — lit r/g/b/brightness/transition_ms depuis un doc JSON
 * déjà parsé, valide et applique. Retourne false si RGB invalide.
 * source : "local_push" | "serial_usb" | "api_pull"
 */
bool applyColorFromDoc(JsonDocument& doc, const char* source,
                       String templateId, String actionKey) {
  int r = doc["r"] | -1;
  int g = doc["g"] | -1;
  int b = doc["b"] | -1;
  if (r < 0 || r > 255 || g < 0 || g > 255 || b < 0 || b > 255) return false;

  uint8_t  brightness = (uint8_t)constrain(
    doc["brightness"] | (int)DEFAULT_BRIGHTNESS, 0, 255);
  uint16_t transMs    = (uint16_t)(doc["transition_ms"] | 500);

  applyColor((uint8_t)r, (uint8_t)g, (uint8_t)b, brightness, transMs);
  lastSource     = source;
  lastTemplateId = templateId;
  lastActionKey  = actionKey;
  return true;
}

// ═════════════════════════════════════════════════════════════════════════════
// JSON + CORS HELPERS HTTP
// ═════════════════════════════════════════════════════════════════════════════

void addCorsHeaders() {
  server.sendHeader("Access-Control-Allow-Origin",  "*");
  server.sendHeader("Access-Control-Allow-Headers", "Content-Type");
  server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
}

void sendJson(int statusCode, JsonDocument& doc) {
  String body;
  serializeJson(doc, body);
  addCorsHeaders();
  server.send(statusCode, "application/json", body);
}

void sendError(int statusCode, const char* error, const char* message = nullptr) {
  StaticJsonDocument<128> doc;
  doc["success"] = false;
  doc["error"]   = error;
  if (message) doc["message"] = message;
  String body;
  serializeJson(doc, body);
  addCorsHeaders();
  server.send(statusCode, "application/json", body);
}

void handleOptions() {
  addCorsHeaders();
  server.send(204);
}

