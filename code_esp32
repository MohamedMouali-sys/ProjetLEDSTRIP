// ═════════════════════════════════════════════════════════════════════════════
// MODE DE CONTRÔLE
// ═════════════════════════════════════════════════════════════════════════════

enum ControlMode { MODE_LOCAL_PUSH, MODE_API_PULL, MODE_DUAL };

String modeToString(ControlMode m) {
  switch (m) {
    case MODE_LOCAL_PUSH: return "local_push";
    case MODE_API_PULL:   return "api_pull";
    case MODE_DUAL:       return "dual";
    default:              return "unknown";
  }
}

ControlMode parseMode(String s) {
  s.toLowerCase(); s.trim();
  if (s == "local_push") return MODE_LOCAL_PUSH;
  if (s == "api_pull")   return MODE_API_PULL;
  if (s == "dual")       return MODE_DUAL;
  return (ControlMode)-1;
}

